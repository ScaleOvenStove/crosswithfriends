{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noFallthroughCasesInSwitch": true,
    "types": ["vite/client", "vitest/globals"],
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@lib/*": ["./src/lib/*"]
    }
  },
  "include": [
    "eslint.config.mjs",
    "pwa-assets.config.ts",
    "src",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
